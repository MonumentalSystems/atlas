# SPDX-License-Identifier: AGPL-3.0-only
#
# Config for scripts/rdma-integration-harness.sh
# Copy to ~/.config/atlas/rdma-harness.env and edit for YOUR machines.
# (Or override any of these with flags / environment variables.)
#
# There are deliberately NO defaults for the three settings below: the harness
# fails fast rather than dialling somebody else's box (AGENTS.md, PCND).

# ssh target for the peer's MANAGEMENT interface (not the RDMA data link).
PEER_SSH=my-peer-box

# The address the CLIENT dials over the RDMA data link. On a fleet with a
# dedicated CX7/RoCE subnet this is usually DIFFERENT from PEER_SSH.
PEER_DATA=10.0.0.2

# NVMe-backed directory on the peer. The per-run swap file is created under a
# unique subdirectory here and removed on teardown.
PEER_SWAP_DIR=/nvme/atlas

# ── optional ────────────────────────────────────────────────────────────────
# Dedicated test port. Must be free on the peer; the harness refuses to reuse a
# port that is already listening.
#PEER_PORT=9930

# Rails as "<ib_device>:<gid_index>", space-separated. Auto-detected from
# /sys/class/infiniband (gid idx 3) on each side when left unset.
#PEER_RAILS="mlx5_0:3 mlx5_1:3"
#CLIENT_RAIL="mlx5_0:3"

# Hard ceilings on the peer. Keep these small: the harness is a correctness
# check, not a benchmark. Defaults stay far under 10 GB of RAM.
#MAX_BLADE_GB=4
#SWAP_CAP_GB=2

# tiny (default): 256 KiB arena, ~2 MiB moved, runs in seconds — CI-friendly.
# stress:         32 MiB arena, ~1 GiB through the peer's swap file.
#PROFILE=tiny

# Leave the peer running after the test (for manual poking). Teardown is skipped.
#KEEP_PEER=1
