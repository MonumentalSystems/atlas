+import cutlass
+import cutlass.cute as cute
+
+
+# ─── CollectiveInverseF32 ────────────────────────────────────────────────────
+# Full-fp32 in-place inverse of the 64×64 unit-lower-triangular WY T-matrix
+# (I + strict_lower(sT)), replacing the fp16 HMMA blockwise CollectiveInverse
+# for the f32-inverse GDN variant. The fp16 collective truncates the KK
+# accumulator to fp16 before the inverse and re-truncates at every blockwise
+# level (8→16→32→64, HMMA fp16 operands); those per-64-token-block errors feed
+# the fp32-carried KV state and accumulate with CONTEXT DEPTH (~3128 blocks at
+# 200K) — the long-context coherence loss. This version is a classic row-Gauss
+# forward elimination computed entirely in fp32: no fp16 operand anywhere.
+#
+# Algorithm (identical math to CollectiveInverse level 1, N=64, smem-resident):
+#   row r>s at step s:  row_r[0..s-1] += (-row_r[s]) * row_s[0..s-1]
+#                       row_r[s]       = -row_r[s]
+# Row s is finalized before step s (its last update happens at step s-1), and
+# step s writes only rows r>s at columns <= s, so the in-place update is safe
+# with one WG-wide barrier per step.
+#
+# Contract (drop-in for CollectiveInverse().run in _kk_store_and_inv):
+#   * sT: (64, 64) smem tensor, fp32, logical (row, col) indexing. On entry the
+#     strict lower triangle holds the masked β·K·Kᵀ values, the diagonal holds
+#     garbage (raw k·k values — treated as 1, as garbage_filled_diagonal=True
+#     does), and the upper triangle is 0 (pre-masked by qk_or_kk_mask).
+#   * On exit: strict lower = the inverse's strict lower, diagonal = 1.0,
+#     upper triangle untouched (still 0) — same post-state the fp16 collective
+#     leaves for the β·T reload that builds the NewV operand.
+#   * Must be called by 128 threads (one warp group); barrier_id free for use.
+#     Rows are owned by threads 0..63; threads 64..127 only arrive at barriers.
+#   * The caller must barrier once more after run() before reading sT.
+#
+# Cost: ~64³/6 fp32 smem-FMAs + 64 WG barriers per 64-token block, CUDA-core
+# work on WG0 that overlaps WG1's QK GEMM — noise vs the block's tensor-core
+# GEMMs. (Headroom if it ever shows up in a profile: split each row across two
+# threads, or block the elimination 8-wide.)
+
+
+class CollectiveInverseF32:
+    @cute.jit
+    def run(self, sT: cute.Tensor, barrier_id: cutlass.Int32):
+        """Invert (I + strict_lower(sT)) in place, fp32 throughout."""
+        tidx, _, _ = cute.arch.thread_idx()
+        thread_idx = tidx % 128
+        n = cutlass.Int32(64)
+
+        for s in cutlass.range(cutlass.Int32(0), n - cutlass.Int32(1), cutlass.Int32(1), unroll=1):
+            # All 128 WG threads arrive; rows s+1.. then update in place.
+            cute.arch.barrier(barrier_id=barrier_id, number_of_threads=128)
+            r = thread_idx
+            if r > s and r < n:
+                row_scale = -cutlass.Float32(sT[r, s])
+                for j in cutlass.range(s, unroll=1):
+                    sT[r, j] = cutlass.Float32(sT[r, j]) + row_scale * cutlass.Float32(
+                        sT[s, j]
+                    )
+                sT[r, s] = row_scale
+
+        # Unit diagonal for the downstream β·T reload (the stored diagonal was
+        # garbage-filled; the elimination never read it).
+        cute.arch.barrier(barrier_id=barrier_id, number_of_threads=128)
+        if thread_idx < n:
+            sT[thread_idx, thread_idx] = cutlass.Float32(1.0)
